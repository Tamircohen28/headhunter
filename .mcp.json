{
  "mcpServers": {
    "gmail": {
      "_setup": "Run once to auth: npx @gongrzhe/server-gmail-autoauth-mcp auth",
      "command": "npx",
      "args": ["-y", "@gongrzhe/server-gmail-autoauth-mcp"],
      "env": {}
    },
    "google-calendar": {
      "_setup": "Set CREDENTIALS_PATH to your Google OAuth credentials.json (see https://github.com/am2rican5/mcp-google-calendar)",
      "command": "npx",
      "args": ["-y", "mcp-google-calendar"],
      "env": {
        "CREDENTIALS_PATH": "${GOOGLE_CALENDAR_CREDENTIALS_PATH}"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "linkedin": {
      "_warning": "UNOFFICIAL community MCP. May violate LinkedIn ToS. Use at your own risk. Remove this block if you don't want it.",
      "command": "npx",
      "args": ["-y", "mcp-linkedin"],
      "env": {
        "LINKEDIN_EMAIL": "${LINKEDIN_EMAIL}",
        "LINKEDIN_PASSWORD": "${LINKEDIN_PASSWORD}"
      }
    }
  }
}
